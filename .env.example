# Local HTTPS and production use the same compose file.
# Production replacement:
# APP_DOMAIN=bot.example.com
# MINI_APP_URL=https://bot.example.com/miniapp/
APP_DOMAIN=localhost
LETSENCRYPT_EMAIL=admin@example.com
POSTGRES_DB=topsbottg
POSTGRES_USER=topsbottg_app
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD
DATABASE_URL=postgresql+asyncpg://topsbottg_app:CHANGE_ME_LONG_RANDOM_PASSWORD@postgres:5432/topsbottg
BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
ADMIN_TELEGRAM_IDS=CHANGE_ME_ADMIN_TELEGRAM_IDS
MINI_APP_URL=https://localhost/miniapp/
BROADCAST_RATE_PER_SECOND=5
LOG_LEVEL=INFO
